  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const mv = document.getElementById('mv');
      const random = Math.floor( Math.random() * 8 ) + 1;

      mv.src = 'img/top_mv0' + random + ".webp";
    })
  </script>

  <script src="/common/js/swiper-bundle.min.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const baseOptions = {
        centeredSlides: false,
        loop: true,
        loopedSlides: 1,
        loopAdditionalSlides: 1,
        speed: 1800,
        autoplay: {
          delay: 4000,
          disableOnInteraction: false,
          waitForTransition: false,
        },
        grabCursor: true,
        watchSlidesProgress: true,
      };

      const swipers = [
        {
          container: '.swiper.swiper-topics',
          nextEl: '.swiper-button-next.topics',
          prevEl: '.swiper-button-prev.topics',
          options: {
            slidesPerView: 2,
            spaceBetween: 8,
            pagination: {
              el: '.swiper-pagination.topics',
            },
            breakpoints: {
              768: {
                spaceBetween: 16,
                slidesPerView: 4,
                // slidesPerView: 3,
              }
            }
          }
        },
        {
          container: '.swiper.swiper-event',
          nextEl: '.swiper-button-next.event',
          prevEl: '.swiper-button-prev.event',
          options: {
            slidesPerView: 2,
            spaceBetween: 12,
            pagination: {
              el: '.swiper-pagination.event',
            },
            breakpoints: {
              768: {
                spaceBetween: 20,
                slidesPerView: 4,
              }
            }
          }
        },
        {
          container: '.swiper.swiper-tokaiinaka',
          nextEl: '.swiper-button-next.tokaiinaka',
          prevEl: '.swiper-button-prev.tokaiinaka',
          options: {
            slidesPerView: 2,
            spaceBetween: 12,
            pagination: {
              el: '.swiper-pagination.tokaiinaka',
            },
            breakpoints: {
              768: {
                spaceBetween: 20,
                slidesPerView: 4,
              }
            }
          }
        },
      ];

      swipers.forEach(swiper => {
        const wrapper = document.querySelector(swiper.container + ' .swiper-wrapper');

        // Swiper初期化
        new Swiper(swiper.container, {
          ...baseOptions,        // 共通オプション
          ...swiper.options,     // 個別オプションをマージ
          navigation: {
            nextEl: swiper.nextEl,
            prevEl: swiper.prevEl
          }
        });
      })
    });
  </script>
  <script>
  (() => {
    document.addEventListener('DOMContentLoaded', () => {
      fetch('/service_status/status.json?t=' + Date.now())
      .then((response) => {
        if (!response.ok) {
          document.getElementById('status-text').textContent = 'データを取得できませんでした。';
          throw new Error('Network response was not ok : ' . response.status);
        }
        return response.text();
      })
      .then(json => {
        const obj = JSON.parse(json);
        if (obj === null || !obj.messages || obj.messages.length === 0) {
          document.getElementById('status-text').textContent = '運行情報はありません。';
          return;
        }
        const messages = obj.messages;
        if (messages.length > 0) {
          setMessage(messages[0]);
        }
      });
    });

    function getStatusIconImage(iconType) {
      switch (iconType) {
        case "o":
          return '<img src="img/train_icon01.png" alt="" width="25" height="25">';
        case "^":
          return '<img src="img/train_icon02.png" alt="" width="26" height="22">';
        case "x":
          return '<img src="img/train_icon03.png" alt="" width="24" height="24">';
        case "!":
          return '<img src="img/train_icon04.png" alt="" width="25" height="25">';
        default:
          return "";
      }
    }

    function setMessage(msg) {

      let iconImg = "";
      let statusEn = "";

      switch (msg.type) {
        case "stdtxt":
          iconImg = getStatusIconImage("o");
          break;
        case "message":
          const statusJa = msg.langs.ja.status;
          iconImg = getStatusIconImage(statusToIconType(statusJa));
          break;
        default:
          break;
      }

      document.getElementById('status-icon').innerHTML = iconImg;

      const a = document.createElement('a');
      a.textContent = msg.langs.ja.text;
      a.href = '/ticket/train/';
      document.getElementById('status-text').appendChild(a);

    }

const STATUS_TYPES ={
    "運転見合わせ":     "x",
    "遅延":             "^",
    "平常運転":         "o",
    "運転再開見込":     "x",
    "お知らせ":         "!",
    "運転再開":         "^",
    "一部運休":         "^",
    "直通運転中止":     "^",
    "運休":             "x",
    "折返し運転":       "^",
    "経路変更":         "^",
    "直通運転再開":     "^",
    "バス代行":         "x",
    "振替輸送":         "x",
    "リフレッシュ工事": "!",
    "一部運転再開":     "^",
};

function statusToIconType(statusJa) {
    return STATUS_TYPES[statusJa] || "";
}

  })();
  </script>
</body>
</html>
